#!/bin/bash
# GoldenGate Manager Start Script
# Generated by Ansible

ORACLE_SID={{ oracle_goldengate_local_db_sid }}
ORAENV_ASK=NO
. oraenv > /dev/null

GGHOME={{ oracle_goldengate_home }}
LOG={{ oracle_goldengate_log_dir }}/start_manager_$(date +%Y%m%d_%H%M%S).log

cd ${GGHOME}

# Check if manager is already running
STATUS=$(./ggsci << EOF 2>&1
INFO MANAGER
EXIT
EOF
)

if echo "${STATUS}" | grep -q "Manager is running"; then
    echo "Manager is already running"
    exit 0
fi

echo "Starting GoldenGate Manager..."

./ggsci << EOF >"$LOG" 2>&1
START MANAGER
INFO MANAGER
EXIT
EOF

if [ $? -eq 0 ] && grep -q "Manager is running\|Manager started" "$LOG"; then
    echo "Manager started successfully"
    exit 0
else
    echo "Failed to start Manager - check log: $LOG"
    cat "$LOG"
    exit 1
fi
