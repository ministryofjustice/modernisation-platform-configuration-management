#!/bin/bash
# GoldenGate Manager Stop Script
# Generated by Ansible

ORACLE_SID={{ oracle_goldengate_local_db_sid }}
ORAENV_ASK=NO
. oraenv > /dev/null

GGHOME={{ oracle_goldengate_home }}

cd ${GGHOME}

# Check if manager is already stopped
STATUS=$(./ggsci << EOF 2>&1
INFO MANAGER
EXIT
EOF
)

if echo "${STATUS}" | grep -q "Manager is DOWN"; then
    echo "Manager is already stopped"
    exit 0
fi

echo "Stopping GoldenGate Manager..."

./ggsci << EOF
STOP MANAGER !
INFO MANAGER
EXIT
EOF

if [ $? -eq 0 ]; then
    echo "Manager stopped successfully"
    exit 0
else
    echo "Failed to stop Manager"
    exit 1
fi
