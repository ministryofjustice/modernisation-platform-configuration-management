#!/bin/bash
# GoldenGate Audit Reference Replicat Start Script
# Generated by Ansible

ORACLE_SID={{ oracle_goldengate_group.auditref.tns_alias }}
ORAENV_ASK=NO
. oraenv > /dev/null

GGHOME={{ oracle_goldengate_home }}
REPLICAT_NAME={{ oracle_goldengate_group.auditref.replicat_name }}
LOG={{ oracle_goldengate_log_dir }}/start_{{ oracle_goldengate_group.auditref.replicat_name }}_$(date +%Y%m%d_%H%M%S).log

cd ${GGHOME}

# if SCN passed in as an argument, use it to start the replicat
if [ $# -eq 1 ]; then
    SCN=$1
    echo "Starting Replicat ${REPLICAT_NAME} with SCN ${SCN}..."
    START=", AFTERSCN ${SCN}"
else
    echo "Starting Replicat ${REPLICAT_NAME}..."
    START=""
fi

./ggsci << EOF >"$LOG" 2>&1
START REPLICAT ${REPLICAT_NAME} ${START}
INFO REPLICAT ${REPLICAT_NAME}
EXIT
EOF

if [ $? -eq 0 ]; then
    echo "Replicat ${REPLICAT_NAME} started successfully with ${START}"
    exit 0
else
    echo "Failed to start Replicat ${REPLICAT_NAME} with ${START}"
    exit 1
fi
