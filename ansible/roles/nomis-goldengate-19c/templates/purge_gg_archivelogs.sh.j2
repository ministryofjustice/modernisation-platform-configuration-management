#!/bin/bash
# purge_gg_archivelogs.sh
# Purge foreign archived redo logs from ASM once they are no longer required
# for GoldenGate downstream integrated capture recovery.
#
# Oracle does not automatically purge foreign archived logs shipped to a
# downstream mining database.  Purge decisions are anchored to the GoldenGate
# Extract Recovery Checkpoint timestamps (the oldest position any extract must
# be able to restart from), minus a configurable safety retention buffer.
# RMAN is used for the actual deletion so that ASM, the control file, and the
# RMAN catalogue remain consistent.
#
# Generated by Ansible - do not edit manually.
# The database SID of the local mining database must be passed as the first argument to this script.

GG_HOME="{{ oracle_goldengate_home }}"
LOG_DIR="{{ oracle_goldengate_log_dir }}"
RETENTION_HOURS="{{ oracle_goldengate_archivelog_retention_hours }}"
LOCAL_SID="$1"

LOG_FILE="${LOG_DIR}/purge_archivelogs_$(date +%Y%m%d_%H%M%S).log"
mkdir -p "$LOG_DIR"
exec > >(tee -a "$LOG_FILE") 2>&1

echo "=== GoldenGate Foreign Archivelog Purge: $(date) ==="
echo "Mining database  : ${LOCAL_SID}"
echo "Retention buffer : ${RETENTION_HOURS} hours beyond extract recovery checkpoint"

# ---------------------------------------------------------------------------
# Oracle environment setup - done once for the local mining database
# ---------------------------------------------------------------------------
export ORACLE_SID="${LOCAL_SID}"
export ORAENV_ASK=NO
# shellcheck source=/dev/null
. oraenv >/dev/null 2>&1

# ---------------------------------------------------------------------------
# get_recovery_checkpoint_time EXTRACT_NAME
#
# Runs GGSCI INFO EXTRACT <name>, DETAIL and parses the Recovery Checkpoint
# timestamp.  Prints "YYYY-MM-DD HH:MM:SS" to stdout, or nothing on failure.
# ---------------------------------------------------------------------------
get_recovery_checkpoint_time() {
    local extract_name="$1"

    local info_output
    info_output=$(
        cd "$GG_HOME" || exit 1
        ./ggsci <<EOF 2>/dev/null
INFO EXTRACT ${extract_name}, DETAIL
EXIT
EOF
    )

    # The DETAIL output contains a "Recovery Checkpoint" block.  Grab the
    # Timestamp line that immediately follows it.
    # Format: "    Timestamp: YYYY-MM-DD HH:MM:SS.FFFFFF"
    local chk_time
    chk_time=$(echo "$info_output" \
        | grep -A 10 "Recovery Checkpoint" \
        | grep "Timestamp:" \
        | head -1 \
        | awk '{print $2, $3}' \
        | cut -d'.' -f1)

    echo "$chk_time"
}

# ---------------------------------------------------------------------------
# calc_purge_cutoff ORACLE_SID EXTRACT_NAME [EXTRACT_NAME ...]
#
# Determines the oldest Recovery Checkpoint timestamp across all supplied
# extracts then subtracts RETENTION_HOURS.  Prints the resulting cutoff
# timestamp to stdout.  Returns 1 (aborting the purge) if the checkpoint
# cannot be determined for any extract, to avoid premature deletion.
# ---------------------------------------------------------------------------
calc_purge_cutoff() {
    local oracle_sid="$1"
    shift
    local extracts=("$@")

    local oldest_epoch=""

    for extract in "${extracts[@]}"; do
        local chk_time
        chk_time=$(get_recovery_checkpoint_time "$extract")

        if [ -z "$chk_time" ]; then
            echo "ERROR: Cannot determine recovery checkpoint for extract ${extract}" \
                 "on ${oracle_sid} - aborting purge to avoid data loss" >&2
            return 1
        fi

        echo "  ${extract} recovery checkpoint : ${chk_time}"

        local epoch
        epoch=$(date -d "$chk_time" '+%s' 2>/dev/null)
        if [ -z "$epoch" ]; then
            echo "ERROR: Could not parse checkpoint timestamp '${chk_time}'" \
                 "for extract ${extract}" >&2
            return 1
        fi

        if [ -z "$oldest_epoch" ] || [ "$epoch" -lt "$oldest_epoch" ]; then
            oldest_epoch="$epoch"
        fi
    done

    local cutoff_epoch=$(( oldest_epoch - RETENTION_HOURS * 3600 ))
    date -d "@${cutoff_epoch}" '+%Y-%m-%d %H:%M:%S'
}

# ---------------------------------------------------------------------------
# purge_foreign_archivelogs ORACLE_SID CUTOFF_TIMESTAMP
#
# Invokes RMAN to delete foreign archived logs completed before CUTOFF.
# RMAN handles ASM paths and updates the control file metadata correctly.
# ---------------------------------------------------------------------------
purge_foreign_archivelogs() {
    local oracle_sid="$1"
    local cutoff_time="$2"

    echo ""
    echo "Connecting RMAN to ${oracle_sid}"
    echo "Deleting foreign archived logs completed before: ${cutoff_time}"

    rman target / nocatalog <<EOF
DELETE NOPROMPT FOREIGN ARCHIVELOG ALL COMPLETED BEFORE TIME "TO_DATE('${cutoff_time}', 'YYYY-MM-DD HH24:MI:SS')";
EXIT;
EOF
    local rc=$?
    if [ "$rc" -ne 0 ]; then
        echo "WARNING: RMAN exited with return code ${rc} for ${oracle_sid}" >&2
    fi
    return "$rc"
}

# ---------------------------------------------------------------------------
# Rotate old purge log files - keep the last 30 days
# ---------------------------------------------------------------------------
find "$LOG_DIR" -maxdepth 1 -name 'purge_archivelogs_*.log' -mtime +30 -delete 2>/dev/null || true

# ---------------------------------------------------------------------------
# Main - determine which extracts are relevant for the local mining database
# ---------------------------------------------------------------------------
case "$LOCAL_SID" in
    "{{ oracle_goldengate_group.auditdata.tns_alias }}")
        echo ""
        echo "--- Audit mining database (${LOCAL_SID}) ---"
        EXTRACTS=(
            "{{ oracle_goldengate_group.auditdata.extract_name }}"
            "{{ oracle_goldengate_group.auditref.extract_name }}"
        )

        CUTOFF=$(calc_purge_cutoff "$LOCAL_SID" "${EXTRACTS[@]}") || {
            echo "Purge skipped for ${LOCAL_SID} - checkpoint lookup failed"
            exit 1
        }

        echo "  Oldest checkpoint - ${RETENTION_HOURS}h buffer = ${CUTOFF}"
        purge_foreign_archivelogs "$LOCAL_SID" "$CUTOFF"
        ;;

    "{{ oracle_goldengate_group.mis.tns_alias }}")
        echo ""
        echo "--- MIS mining database (${LOCAL_SID}) ---"
        EXTRACTS=(
            "{{ oracle_goldengate_group.mis.extract_name }}"
        )

        CUTOFF=$(calc_purge_cutoff "$LOCAL_SID" "${EXTRACTS[@]}") || {
            echo "Purge skipped for ${LOCAL_SID} - checkpoint lookup failed"
            exit 1
        }

        echo "  Oldest checkpoint - ${RETENTION_HOURS}h buffer = ${CUTOFF}"
        purge_foreign_archivelogs "$LOCAL_SID" "$CUTOFF"
        ;;

    "")
        echo "oracle_goldengate_local_db_sid is not set - nothing to purge"
        exit 0
        ;;

    *)
        echo "No downstream mining database recognised on this host" \
             "(oracle_goldengate_local_db_sid='${LOCAL_SID}')"
        exit 0
        ;;
esac

echo ""
echo "=== Purge completed: $(date) ==="
