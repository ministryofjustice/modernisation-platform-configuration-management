#!/bin/bash
# GoldenGate MIS Extract Start Script
# Generated by Ansible

ORACLE_SID={{ oracle_goldengate_group.mis.tns_alias }}
ORAENV_ASK=NO
. oraenv > /dev/null

GGHOME={{ oracle_goldengate_home }}
EXTRACT_NAME={{ oracle_goldengate_group.mis.extract_name }}
LOG={{ oracle_goldengate_log_dir }}/start_{{ oracle_goldengate_group.mis.extract_name }}_$(date +%Y%m%d_%H%M%S).log

cd ${GGHOME}

# if SCN passed in as an argument, use it to start the extract
if [ $# -eq 1 ]; then
    SCN=$1
    echo "Starting Extract ${EXTRACT_NAME} with SCN ${SCN}..."
    START="SCN ${SCN}"
else
    echo "Starting Extract ${EXTRACT_NAME}..."
    START="BEGIN NOW"
fi

./ggsci << EOF >"$LOG" 2>&1
DBLOGIN USERIDALIAS MIS_DB
ALTER EXTRACT ${EXTRACT_NAME}, ${START}
START EXTRACT ${EXTRACT_NAME}
INFO EXTRACT ${EXTRACT_NAME}
EXIT
EOF

if [ $? -eq 0 ]; then
    echo "Extract ${EXTRACT_NAME} started successfully with ${START}"
    exit 0
else
    echo "Failed to start Extract ${EXTRACT_NAME} with ${START}"
    exit 1
fi
