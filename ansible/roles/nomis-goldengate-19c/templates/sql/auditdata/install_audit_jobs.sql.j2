spool /tmp/{{ oracle_goldengate_group_name }}_audit_jobs.log

SET SERVEROUTPUT ON
WHENEVER SQLERROR EXIT SUCCESS

PROMPT Installing AUDIT database scheduler jobs (disabled initially)
PROMPT ===============================================================
PROMPT Migrating 17 jobs from STRMADMIN:
PROMPT   Jobs to enable at switchover: 10
PROMPT   Jobs to keep disabled: 7
PROMPT ===============================================================

DECLARE
    v_job_name VARCHAR2(30);
    v_exists NUMBER;
BEGIN
    DBMS_OUTPUT.PUT_LINE('Creating AUDIT jobs migrated from STRMADMIN...');
    
    -- Job 1: ADD_WKLY_DATA_PARTS (add partitions weekly)
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = '{{ oracle_goldengate_group.auditdata.schema_owner }}' 
        AND job_name = 'ADD_WKLY_DATA_PARTS';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => '{{ oracle_goldengate_group.auditdata.schema_owner }}.ADD_WKLY_DATA_PARTS',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'begin
   {{ oracle_goldengate_group.auditdata.schema_owner }}.AUDITDATA_JOB_PKG.add_partitions(''AUDIT_TABLE'');
   {{ oracle_goldengate_group.auditdata.schema_owner }}.AUDITDATA_JOB_PKG.add_partitions(''AUDIT_COLUMN'');
   {{ oracle_goldengate_group.auditdata.schema_owner }}.AUDITDATA_JOB_PKG.add_partitions(''AUDIT_OFFENDER_REF'');
   {{ oracle_goldengate_group.auditdata.schema_owner }}.AUDITDATA_JOB_PKG.add_partitions(''REMOTE_AUDIT_TRAIL'');
   {{ oracle_goldengate_group.auditdata.schema_owner }}.AUDITDATA_JOB_PKG.add_partitions(''OS_LOG_EVENT'');
end;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=WEEKLY; BYDAY=SUN; BYHOUR=12; BYMINUTE=0',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated from STRMADMIN.ADD_WKLY_DATA_PARTS - Add new partitions weekly');
            DBMS_OUTPUT.PUT_LINE('Created job: ADD_WKLY_DATA_PARTS');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job ADD_WKLY_DATA_PARTS already exists');
        END IF;
    END;
    
    -- Job 2: ARCH_WKLY_DATA_PARTS (export partitions to datapump)
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = '{{ oracle_goldengate_group.auditdata.schema_owner }}' 
        AND job_name = 'ARCH_WKLY_DATA_PARTS';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => '{{ oracle_goldengate_group.auditdata.schema_owner }}.ARCH_WKLY_DATA_PARTS',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'begin {{ oracle_goldengate_group.auditdata.schema_owner }}.AUD_ARCH_PKG1.EXPORT_CONTROL(TRUE); end;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=WEEKLY; BYDAY=MON; BYHOUR=4; BYMINUTE=0',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated from STRMADMIN.ARCH_WKLY_DATA_PARTS - Export partitions to /u02/audit_db/datapump');
            DBMS_OUTPUT.PUT_LINE('Created job: ARCH_WKLY_DATA_PARTS');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job ARCH_WKLY_DATA_PARTS already exists');
        END IF;
    END;
    
    -- Job 3: AUDIT DEQUEUE (disabled - procedure doesn't exist)
    DBMS_OUTPUT.PUT_LINE('NOTE: AUDIT DEQUEUE not migrated - procedure audit_dequeue no longer exists');
    
    -- Job 4: AUDIT_DATA_PURGE (delete old records/partitions)
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = '{{ oracle_goldengate_group.auditdata.schema_owner }}' 
        AND job_name = 'AUDIT_DATA_PURGE';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => '{{ oracle_goldengate_group.auditdata.schema_owner }}.AUDIT_DATA_PURGE',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'begin
   {{ oracle_goldengate_group.auditdata.schema_owner }}.AUD_ARCH_PKG1.PURGE_PARTITIONS;
   {{ oracle_goldengate_group.auditdata.schema_owner }}.AUD_ARCH_PKG1.PURGE_RECORDS;
   {{ oracle_goldengate_group.auditref.schema_owner }}.AUDITREF_JOB_PKG.PURGE_RECORDS(''{{ oracle_goldengate_group.auditref.schema_owner }}'');
end;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=WEEKLY; BYDAY=TUE; BYHOUR=5; BYMINUTE=0',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated from STRMADMIN.AUDIT_DATA_PURGE - Delete old records and partitions');
            DBMS_OUTPUT.PUT_LINE('Created job: AUDIT_DATA_PURGE');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job AUDIT_DATA_PURGE already exists');
        END IF;
    END;
    
    -- Job 5: AUDIT_DATA_UPLOAD_TO_S3 (PDCNMAUD only)
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = 'SYS' 
        AND job_name = 'AUDIT_DATA_UPLOAD_TO_S3';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => 'SYS.AUDIT_DATA_UPLOAD_TO_S3',
                job_type         => 'EXECUTABLE',
                job_action       => '/home/oracle/admin/scripts/audit_data_s3_upload.sh',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=WEEKLY; BYDAY=TUE; BYHOUR=8; BYMINUTE=0',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated from STRMADMIN.AUDIT_DATA_UPLOAD_TO_S3 - Upload to S3 (PDCNMAUD only)');
            DBMS_OUTPUT.PUT_LINE('Created job: AUDIT_DATA_UPLOAD_TO_S3');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job AUDIT_DATA_UPLOAD_TO_S3 already exists');
        END IF;
    END;
    
    -- Job 6: AUDIT_LOG_IMPORT_CHAIN_JOB (disabled - not needed, last run 2018)
    DBMS_OUTPUT.PUT_LINE('NOTE: AUDIT_LOG_IMPORT_CHAIN_JOB not migrated - last run 2018, not needed');
    
    -- Job 7: AUDIT_REFERENCE (disabled - same as OFFENDER_CROSS_REFERENCE_UPD)
    DBMS_OUTPUT.PUT_LINE('NOTE: AUDIT_REFERENCE not migrated - same as OFFENDER_CROSS_REFERENCE_UPD');
    
    -- Job 8: BKUP_WKLY_RO_TABLESPACES (disabled - SBT tablespace doesn''t exist)
    DBMS_OUTPUT.PUT_LINE('NOTE: BKUP_WKLY_RO_TABLESPACES not migrated - SBT tablespace doesn''t exist');
    
    -- Job 9: DAILY_LOG_PURGE (disabled - script in crontab)
    DBMS_OUTPUT.PUT_LINE('NOTE: DAILY_LOG_PURGE not migrated - script runs from root crontab');
    
    -- Job 10: GATHER_STATS_AUDITDATA_TABS
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = '{{ oracle_goldengate_group.auditdata.schema_owner }}' 
        AND job_name = 'GATHER_STATS_AUDITDATA_TABS';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => '{{ oracle_goldengate_group.auditdata.schema_owner }}.GATHER_STATS_AUDITDATA_TABS',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'BEGIN {{ oracle_goldengate_group.auditdata.schema_owner }}.AUDITDATA_JOB_PKG.gather_stats_auditdata_tables(); END;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=WEEKLY; BYDAY=SAT; BYHOUR=4',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated from STRMADMIN.GATHER_STATS_AUDITDATA_TABS');
            DBMS_OUTPUT.PUT_LINE('Created job: GATHER_STATS_AUDITDATA_TABS');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job GATHER_STATS_AUDITDATA_TABS already exists');
        END IF;
    END;
    
    -- Job 11: GATHER_STATS_AUDITREF_TABS
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = '{{ oracle_goldengate_group.auditref.schema_owner }}' 
        AND job_name = 'GATHER_STATS_AUDITREF_TABS';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => '{{ oracle_goldengate_group.auditref.schema_owner }}.GATHER_STATS_AUDITREF_TABS',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'BEGIN {{ oracle_goldengate_group.auditref.schema_owner }}.AUDITREF_JOB_PKG.gather_stats_auditref_tables(); END;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=WEEKLY; BYDAY=SAT; BYHOUR=4',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated from STRMADMIN.GATHER_STATS_AUDITREF_TABS');
            DBMS_OUTPUT.PUT_LINE('Created job: GATHER_STATS_AUDITREF_TABS');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job GATHER_STATS_AUDITREF_TABS already exists');
        END IF;
    END;
    
    -- Job 12: GATHER_STATS_AUDIT_COLUMN
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = '{{ oracle_goldengate_group.auditdata.schema_owner }}' 
        AND job_name = 'GATHER_STATS_AUDIT_COLUMN';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => '{{ oracle_goldengate_group.auditdata.schema_owner }}.GATHER_STATS_AUDIT_COLUMN',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'BEGIN DBMS_STATS.GATHER_TABLE_STATS(''{{ oracle_goldengate_group.auditdata.schema_owner }}'', ''AUDIT_COLUMN''); END;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=WEEKLY; BYDAY=SAT; BYHOUR=4',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated from STRMADMIN.GATHER_STATS_AUDIT_COLUMN');
            DBMS_OUTPUT.PUT_LINE('Created job: GATHER_STATS_AUDIT_COLUMN');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job GATHER_STATS_AUDIT_COLUMN already exists');
        END IF;
    END;
    
    -- Job 13: GATHER_STATS_AUDIT_TABLE
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = '{{ oracle_goldengate_group.auditdata.schema_owner }}' 
        AND job_name = 'GATHER_STATS_AUDIT_TABLE';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => '{{ oracle_goldengate_group.auditdata.schema_owner }}.GATHER_STATS_AUDIT_TABLE',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'BEGIN DBMS_STATS.GATHER_TABLE_STATS(''{{ oracle_goldengate_group.auditdata.schema_owner }}'', ''AUDIT_TABLE''); END;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=DAILY; BYHOUR=4',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated from STRMADMIN.GATHER_STATS_AUDIT_TABLE');
            DBMS_OUTPUT.PUT_LINE('Created job: GATHER_STATS_AUDIT_TABLE');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job GATHER_STATS_AUDIT_TABLE already exists');
        END IF;
    END;
    
    -- Job 14: OFFENDER_CROSS_REFERENCE_UPD (runs at 7am, 3pm, 11pm)
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = '{{ oracle_goldengate_group.auditdata.schema_owner }}' 
        AND job_name = 'OFFENDER_CROSS_REFERENCE_UPD';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => '{{ oracle_goldengate_group.auditdata.schema_owner }}.OFFENDER_CROSS_REFERENCE_UPD',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'declare
    v_plsql varchar2(200);
begin
    v_plsql := ''alter system flush shared_pool'';
    execute immediate v_plsql;
    {{ oracle_goldengate_group.auditdata.schema_owner }}.AUDITDATA_JOB_PKG.populate_offender_refs;
end;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=DAILY; BYHOUR=7,15,23; BYMINUTE=0; BYSECOND=0',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated from STRMADMIN.OFFENDER_CROSS_REFERENCE_UPD - Runs at 7am, 3pm, 11pm');
            DBMS_OUTPUT.PUT_LINE('Created job: OFFENDER_CROSS_REFERENCE_UPD');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job OFFENDER_CROSS_REFERENCE_UPD already exists');
        END IF;
    END;
    
    -- Job 15: ORCL_BATCH_STATUS_EXTRACT_JOB (disabled, last run 2018)
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = '{{ oracle_goldengate_group.auditdata.schema_owner }}' 
        AND job_name = 'ORCL_BATCH_STATUS_EXTRACT_JOB';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => '{{ oracle_goldengate_group.auditdata.schema_owner }}.ORCL_BATCH_STATUS_EXTRACT_JOB',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'BEGIN {{ oracle_goldengate_group.auditdata.schema_owner }}.ORCL_BATCH_PKG.EXTRACT_ORCL_JOB_DATA(''audit'', ''ORCL_BATCH_STATUS_EXTRACT_JOB''); END;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=HOURLY',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated from STRMADMIN.ORCL_BATCH_STATUS_EXTRACT_JOB - Last run 2018, keep disabled');
            DBMS_OUTPUT.PUT_LINE('Created job: ORCL_BATCH_STATUS_EXTRACT_JOB (disabled - last run 2018)');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job ORCL_BATCH_STATUS_EXTRACT_JOB already exists');
        END IF;
    END;
    
    -- Job 16: REMOTE_AUDIT_IMPORT (disabled, last run March 2023)
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = '{{ oracle_goldengate_group.auditdata.schema_owner }}' 
        AND job_name = 'REMOTE_AUDIT_IMPORT';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => '{{ oracle_goldengate_group.auditdata.schema_owner }}.REMOTE_AUDIT_IMPORT',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'execute immediate ''begin {{ oracle_goldengate_group.auditdata.schema_owner }}.AUD_DBA_IMP_PKG1.update_remote_audit_records; end;'';',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=DAILY; BYHOUR=21; BYMINUTE=0; BYSECOND=0',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated from STRMADMIN.REMOTE_AUDIT_IMPORT - Last run March 2023, keep disabled');
            DBMS_OUTPUT.PUT_LINE('Created job: REMOTE_AUDIT_IMPORT (disabled - last run March 2023)');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job REMOTE_AUDIT_IMPORT already exists');
        END IF;
    END;
    
    -- Job 17: WEEKLY_LOG_PURGE (disabled, doesn't work)
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = 'SYS' 
        AND job_name = 'AUDIT_WEEKLY_LOG_PURGE';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => 'SYS.AUDIT_WEEKLY_LOG_PURGE',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'begin {{ oracle_goldengate_group.auditdata.schema_owner }}.AUDITDATA_JOB_PKG.log_purge(); end;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=WEEKLY; BYDAY=WED; BYHOUR=22; BYMINUTE=30; BYSECOND=0',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated from STRMADMIN.WEEKLY_LOG_PURGE - Keep disabled, ineffective');
            DBMS_OUTPUT.PUT_LINE('Created job: AUDIT_WEEKLY_LOG_PURGE (disabled - ineffective)');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job AUDIT_WEEKLY_LOG_PURGE already exists');
        END IF;
    END;
    
    DBMS_OUTPUT.PUT_LINE(CHR(10) || 'AUDIT jobs installation completed');
    DBMS_OUTPUT.PUT_LINE('Jobs to be enabled at switchover: 10');
    DBMS_OUTPUT.PUT_LINE('Jobs to remain disabled: 3');
    DBMS_OUTPUT.PUT_LINE('Jobs not migrated: 4');
    
EXCEPTION
    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('Error creating jobs: ' || SQLERRM);
        RAISE;
END;
/

PROMPT 
PROMPT Listing created AUDIT jobs:
SELECT owner, job_name, enabled, state, comments
FROM dba_scheduler_jobs
WHERE (owner IN ('{{ oracle_goldengate_group.auditdata.schema_owner }}', '{{ oracle_goldengate_group.auditref.schema_owner }}'))
   OR (owner = 'SYS' AND job_name LIKE 'AUDIT_%')
ORDER BY owner, job_name;

PROMPT
PROMPT Completed installation of AUDIT jobs
spool off
