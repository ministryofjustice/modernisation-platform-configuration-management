spool /tmp/{{ oracle_goldengate_group_name }}_jobs_switchover.log

SET SERVEROUTPUT ON
WHENEVER SQLERROR CONTINUE

PROMPT ========================================================================
PROMPT CNOM Scheduler Jobs Switchover Script
PROMPT ========================================================================
PROMPT This script will:
PROMPT   1. Disable all 4 STRMADMIN-owned jobs
PROMPT   2. Enable 1 new job (BUILD_LOGMINER_DICT_HOURLY)
PROMPT   3. Other migrated jobs remain DISABLED (all old/unused)
PROMPT ========================================================================

DECLARE
    v_job_name VARCHAR2(100);
    v_count NUMBER := 0;
BEGIN
    DBMS_OUTPUT.PUT_LINE(CHR(10) || 'Step 1: Disabling STRMADMIN jobs...');
    DBMS_OUTPUT.PUT_LINE('----------------------------------------');
    
    FOR rec IN (SELECT owner, job_name, enabled 
                FROM dba_scheduler_jobs 
                WHERE owner = 'STRMADMIN'
                ORDER BY job_name) LOOP
        v_job_name := rec.owner || '.' || rec.job_name;
        
        IF rec.enabled = 'TRUE' THEN
            BEGIN
                DBMS_SCHEDULER.DISABLE(name => v_job_name, force => TRUE);
                DBMS_OUTPUT.PUT_LINE('  DISABLED: ' || v_job_name);
                v_count := v_count + 1;
            EXCEPTION
                WHEN OTHERS THEN
                    DBMS_OUTPUT.PUT_LINE('  ERROR disabling ' || v_job_name || ': ' || SQLERRM);
            END;
        ELSE
            DBMS_OUTPUT.PUT_LINE('  ALREADY DISABLED: ' || v_job_name);
        END IF;
    END LOOP;
    
    DBMS_OUTPUT.PUT_LINE(CHR(10) || 'Total STRMADMIN jobs disabled: ' || v_count);
    
    -- Step 2: Enable new jobs
    v_count := 0;
    DBMS_OUTPUT.PUT_LINE(CHR(10) || 'Step 2: Enabling new CNOM jobs...');
    DBMS_OUTPUT.PUT_LINE('----------------------------------------');
    
    -- Enable BUILD_LOGMINER_DICT_HOURLY job
    FOR rec IN (SELECT owner, job_name, enabled 
                FROM dba_scheduler_jobs 
                WHERE owner = 'SYS'
                AND job_name = 'BUILD_LOGMINER_DICT_HOURLY'
                ORDER BY job_name) LOOP
        v_job_name := rec.owner || '.' || rec.job_name;
        
        IF rec.enabled = 'FALSE' THEN
            BEGIN
                DBMS_SCHEDULER.ENABLE(name => v_job_name);
                DBMS_OUTPUT.PUT_LINE('  ENABLED: ' || v_job_name);
                v_count := v_count + 1;
            EXCEPTION
                WHEN OTHERS THEN
                    DBMS_OUTPUT.PUT_LINE('  ERROR enabling ' || v_job_name || ': ' || SQLERRM);
            END;
        ELSE
            DBMS_OUTPUT.PUT_LINE('  ALREADY ENABLED: ' || v_job_name);
        END IF;
    END LOOP;
    
    DBMS_OUTPUT.PUT_LINE(CHR(10) || 'Total new jobs enabled: ' || v_count);

    -- Remove the call to run job STRMADMIN.END_OF_MIS_DAY in the program END_OF_DAY_MIS, and replace it with a call to run the new job OMS_OWNER.END_OF_MIS_DAY_JOB instead, as part of the switchover. This is because the END_OF_DAY_MIS program is part of the CNOMIS_FINANCE_MON_SAT_CHAIN chain and is triggered by the END_OF_DAY_MIS_STEP step in that chain, so it doesn't need to be enabled as it's not scheduled to run on its own. It will be triggered by the chain when the time comes.
    BEGIN
        DBMS_SCHEDULER.SET_ATTRIBUTE (
            name         => 'OMS_OWNER.END_OF_DAY_MIS'
            attribute => 'program_action',
            value       => 'BEGIN DBMS_SCHEDULER.RUN_JOB(''{{ oracle_goldengate_group.source.schema_owner }}.END_OF_MIS_DAY_JOB'',FALSE); END;');
    END;

    DBMS_OUTPUT.PUT_LINE(CHR(10) || 'Step 3: Review migrated CNOM jobs...');
    DBMS_OUTPUT.PUT_LINE('----------------------------------------');
    DBMS_OUTPUT.PUT_LINE('All 3 migrated CNOM jobs remain DISABLED:');
    DBMS_OUTPUT.PUT_LINE('  - BATCH_STATUS_EXTRACT_JOB (last run 2018, output dir missing)');
    DBMS_OUTPUT.PUT_LINE('  - ORCL_BATCH_STATUS_EXTRACT_JOB (last run 2018, output dir missing)');
    DBMS_OUTPUT.PUT_LINE('  - CNOM_WEEKLY_DD_DUMP (never run, not needed with hourly dict builds)');
    DBMS_OUTPUT.PUT_LINE(CHR(10) || 'Not migrated:');
    DBMS_OUTPUT.PUT_LINE('  - MIS_BATCH_CONTROL_CHAIN_JOB (complex dependencies - requires manual migration)');
    
END;
/

PROMPT 
PROMPT Current status of all scheduler jobs:
PROMPT ========================================================================
SELECT 
    RPAD(owner, 15) AS owner,
    RPAD(job_name, 40) AS job_name,
    RPAD(enabled, 8) AS enabled,
    RPAD(state, 12) AS state,
    RPAD(NVL(TO_CHAR(last_start_date, 'YYYY-MM-DD HH24:MI'), 'Never'), 17) AS last_run
FROM dba_scheduler_jobs
WHERE owner IN ('STRMADMIN', '{{ oracle_goldengate_group.source.schema_owner }}', 'SYS')
AND (owner != 'SYS' OR job_name LIKE 'CNOM_%')
ORDER BY owner, job_name;

PROMPT
PROMPT Switchover completed
PROMPT Note: BUILD_LOGMINER_DICT_HOURLY enabled (builds dictionary for GoldenGate)
PROMPT Note: All migrated CNOM jobs remain disabled - none are production-ready
spool off
