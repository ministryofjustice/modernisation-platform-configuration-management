spool /tmp/{{ oracle_goldengate_group_name }}_jobs.log

SET SERVEROUTPUT ON
WHENEVER SQLERROR EXIT SUCCESS

PROMPT Installing CNOM scheduler jobs (disabled initially)
PROMPT =====================================================
PROMPT Migrating 4 jobs from STRMADMIN:
PROMPT   1. DAILY_DD_DUMP ->  -> Migrate
PROMPT   2. END_OF_MIS_DAY -> Complex, requires MIS_STOP_POINT table, add_mis_stop_point procedure, MIS_STRM_LINK database link and MIS_BATCH_CONTROL program on remote database -> Migrate but keep disabled until manual migration of dependencies completed
PROMPT   3. ORCL_BATCH_STATUS_EXTRACT_JOB -> Keep disabled (last run 2018)
PROMPT   4. WEEKLY_DD_DUMP -> Keep disabled (never run, not needed)
PROMPT 
PROMPT Creating new job:
PROMPT   5. BUILD_LOGMINER_DICT_HOURLY -> SYS (ENABLED) - Builds dictionary every hour
PROMPT =====================================================

DECLARE
    v_job_name VARCHAR2(30);
    v_exists NUMBER;
BEGIN
    DBMS_OUTPUT.PUT_LINE('Creating CNOM jobs migrated from STRMADMIN...');
    
    -- Job 1: DAILY_DD_DUMP (migrate)
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = 'SYS' 
        AND job_name = 'DAILY_DD_DUMP';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => 'SYS.DAILY_DD_DUMP',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'DECLARE v_scn NUMBER(38); BEGIN dbms_capture_adm.build(first_scn=>v_scn); END;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=DAILY;BYHOUR=20;BYMINUTE=30;BYSECOND=0',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated - Ensure data dictionary is extracted to the redo logs daily for GoldenGate');
            DBMS_OUTPUT.PUT_LINE('Created job: DAILY_DD_DUMP');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job DAILY_DD_DUMP already exists');
        END IF;
    END;
    
    -- Job 2: END_OF_MIS_DAY
    -- NOTE: This job is complex and requires migration of:
    --   - strmadmin.mis_stop_point table
    --   - add_mis_stop_point procedure
    --   - MIS_STRM_LINK database link
    --   - MIS_BATCH_CONTROL program on remote database
    -- There's a step, END_OF_DAY_MIS_STEP, in the chain CNOMIS_FINANCE_MON_SAT_CHAIN, which runs program OMS_OWNER.END_OF_DAY_MIS, which calls this job.

    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = '{{ oracle_goldengate_group.source.schema_owner }}' 
        AND job_name = 'END_OF_MIS_DAY';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => '{{ oracle_goldengate_group.source.schema_owner }}.END_OF_MIS_DAY',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'BEGIN {{ oracle_goldengate_group.source.schema_owner }}.MIS_END_OF_DAY_PKG.run_batch; END;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=DAILY;BYHOUR=20;BYMINUTE=30;BYSECOND=0',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated - Job to trigger MIS end of day processing on downstream database.');
            DBMS_OUTPUT.PUT_LINE('Created job: END_OF_MIS_DAY (disabled - is needed)');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job END_OF_MIS_DAY already exists');
        END IF;
    END;

    -- Need to use dbms_scheduler.set_attribute to change the 'program_action' attribute of the program to run OMS_OWNER.END_OF_MIS_DAY.
        -- Note: This job is part of the CNOMIS_FINANCE_MON_SAT_CHAIN chain and is triggered by the END_OF_DAY_MIS_STEP step in that chain, so it doesn't need to be enabled as it's not scheduled to run on its own. It will be triggered by the chain when the time comes.
        -- DBMS_SCHEDULER.SET_ATTRIBUTE('CNOMIS_FINANCE_MON_SAT_CHAIN', 'program_action', 'OMS_OWNER.END_OF_DAY_MIS');
   -- do this in the switchover instead - how do we test it? dbms_scheduler.set_attribute(
        name => 'CNOMIS_FINANCE_MON_SAT_CHAIN',
        attribute => 'program_action',
        value => 'BEGIN DBMS_SCHEDULER.RUN_JOB('''{{ oracle_goldengate_group.source.schema_owner }}.END_OF_MIS_DAY''',FALSE); END;'
    );
    DBMS_OUTPUT.PUT_LINE('Updated program_action for CNOMIS_FINANCE_MON_SAT_CHAIN to call {{ oracle_goldengate_group.source.schema_owner }}.END_OF_MIS_DAY');
    
    -- Job 3: ORCL_BATCH_STATUS_EXTRACT_JOB (disabled, last run 2018)
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = '{{ oracle_goldengate_group.source.schema_owner }}' 
        AND job_name = 'ORCL_BATCH_STATUS_EXTRACT_JOB';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => '{{ oracle_goldengate_group.source.schema_owner }}.ORCL_BATCH_STATUS_EXTRACT_JOB',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'BEGIN {{ oracle_goldengate_group.source.schema_owner }}.ORCL_BATCH_PKG.EXTRACT_ORCL_JOB_DATA(''cnomis'', ''ORCL_BATCH_STATUS_EXTRACT_JOB''); END;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=HOURLY',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated - Extracts Oracle Scheduler run log data and uploads it to the central batch scheduling file store. Last run in 2018, keep disabled until needed.');
            DBMS_OUTPUT.PUT_LINE('Created job: ORCL_BATCH_STATUS_EXTRACT_JOB (disabled - last run 2018)');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job ORCL_BATCH_STATUS_EXTRACT_JOB already exists');
        END IF;
    END;
    
    -- Job 4: WEEKLY_DD_DUMP (disabled, never run, not needed with hourly dictionary builds)
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = 'SYS' 
        AND job_name = 'CNOM_WEEKLY_DD_DUMP';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => 'SYS.CNOM_WEEKLY_DD_DUMP',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'declare v_scn Number(38); begin dbms_capture_adm.build(first_scn=>v_scn); end;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=WEEKLY; BYDAY=MON,TUE,WED,THU,FRI,SAT,SUN; BYHOUR=21; BYMINUTE=45',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Migrated - Ensure data dictionary is extracted to the redo logs. Never run, not needed (hourly dict builds instead)');
            DBMS_OUTPUT.PUT_LINE('Created job: CNOM_WEEKLY_DD_DUMP (disabled - never run, not needed)');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job CNOM_WEEKLY_DD_DUMP already exists');
        END IF;
    END;
    
    -- Job 5: BUILD_LOGMINER_DICT_HOURLY (new job for GoldenGate Integrated Extract)
    BEGIN
        SELECT COUNT(*) INTO v_exists 
        FROM dba_scheduler_jobs 
        WHERE owner = 'SYS' 
        AND job_name = 'BUILD_LOGMINER_DICT_HOURLY';
        
        IF v_exists = 0 THEN
            DBMS_SCHEDULER.CREATE_JOB (
                job_name         => 'SYS.BUILD_LOGMINER_DICT_HOURLY',
                job_type         => 'PLSQL_BLOCK',
                job_action       => 'BEGIN 
        DBMS_LOGMNR_D.BUILD(
          options => DBMS_LOGMNR_D.STORE_IN_REDO_LOGS
        ); 
      END;',
                start_date       => SYSTIMESTAMP,
                repeat_interval  => 'FREQ=HOURLY; INTERVAL=1',
                enabled          => FALSE,
                auto_drop        => FALSE,
                comments         => 'Build LogMiner dictionary every hour for GoldenGate Integrated Extract');
            DBMS_OUTPUT.PUT_LINE('Created job: BUILD_LOGMINER_DICT_HOURLY (will be enabled at switchover)');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Job BUILD_LOGMINER_DICT_HOURLY already exists');
        END IF;
    END;
    
    DBMS_OUTPUT.PUT_LINE(CHR(10) || 'CNOM jobs installation completed');
    DBMS_OUTPUT.PUT_LINE('Note: All 4 jobs created in DISABLED state');
    DBMS_OUTPUT.PUT_LINE('Note: MIS_BATCH_CONTROL_CHAIN_JOB requires manual migration');
    DBMS_OUTPUT.PUT_LINE('Note: BUILD_LOGMINER_DICT_HOURLY created - will be enabled at switchover');
    
EXCEPTION
    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('Error creating jobs: ' || SQLERRM);
        RAISE;
END;
/

-- In source db create job to run this procedure every hour or so to keep the logminer dictionary fresh. This is needed for integrated extract to work well and avoid missing transactions due to dictionary changes in the source db. The procedure will build the logminer dictionary in the redo logs which means it will be available to goldengate without the need to create a separate dictionary file and manage it on the filesystem. See https://alexlima.com/2025/05/30/why-you-should-rebuild-the-logminer-dictionary-periodically-for-oracle-goldengate/ for more details.

PROMPT Printing the latest scn of the redo log with the data dict in it:
SELECT * FROM (
  SELECT 
    sequence#,
    first_change#,
    TO_CHAR(completion_time, 'YYYY-MM-DD HH24:MI:SS') AS completion_time,
    dictionary_begin,
    dictionary_end
  FROM v$archived_log 
  WHERE (dictionary_begin = 'YES' OR dictionary_end = 'YES') 
    AND STANDBY_DEST = 'NO' 
    AND NAME IS NOT NULL 
    AND STATUS = 'A'
  ORDER BY sequence# DESC)
WHERE ROWNUM = 1;

PROMPT
PROMPT Completed installation of CNOM jobs
spool off
