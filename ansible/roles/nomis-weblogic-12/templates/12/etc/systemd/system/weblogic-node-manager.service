[Unit]
Description=weblogic-node-manager
After=network-online.target

[Service]
ExecStart=/home/oracle/admin/scripts/startNodeManager.sh
ExecStop=/home/oracle/admin/scripts/stopNodeManager.sh
Group=oinstall
RemainAfterExit=yes
TasksMax=infinity
Type=oneshot
User=oracle
LimitSTACK=10M
LimitMEMLOCK=1G

[Install]
WantedBy=multi-user.target
