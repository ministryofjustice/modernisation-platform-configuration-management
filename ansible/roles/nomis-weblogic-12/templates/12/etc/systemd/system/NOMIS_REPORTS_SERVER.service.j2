[Unit]
Description=NOMIS_REPORTS_SERVER
After=WLS_REPORTS.service
PartOf=weblogic-node-manager.service

[Service]
ExecStart=/home/oracle/admin/scripts/startNomisReportsServer.sh {{ reports_server }}
ExecStop=/home/oracle/admin/scripts/stopNomisReportsServer.sh {{ reports_server }}
Group=oinstall
RemainAfterExit=yes
TasksMax=infinity
TimeoutStartSec=300
Type=oneshot
User=oracle

[Install]
WantedBy=multi-user.target
