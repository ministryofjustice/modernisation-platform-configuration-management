[Unit]
Description=weblogic-ohs
After=weblogic-node-manager.service

[Service]
ExecStart=/home/oracle/admin/scripts/startOHS.sh
ExecStop=/home/oracle/admin/scripts/stopOHS.sh
Group=oinstall
RemainAfterExit=yes
TasksMax=infinity
Type=oneshot
User=oracle
LimitSTACK=10M
LimitMEMLOCK=1G

[Install]
WantedBy=multi-user.target
