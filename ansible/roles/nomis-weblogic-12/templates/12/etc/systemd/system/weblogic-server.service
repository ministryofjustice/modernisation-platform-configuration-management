[Unit]
Description=weblogic-server
After=weblogic-node-manager.service

[Service]
ExecStart=/home/oracle/admin/scripts/startWebLogic.sh
ExecStop=/home/oracle/admin/scripts/stopWebLogic.sh
Group=oinstall
RemainAfterExit=yes
TasksMax=infinity
TimeoutStartSec=180
Type=oneshot
User=oracle
LimitSTACK=10M
LimitMEMLOCK=1G

[Install]
WantedBy=multi-user.target
